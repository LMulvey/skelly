{
	"name": "api",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsup src/index.ts --format esm --platform node --target node18 --out-dir dist --clean",
		"start": "node dist/index.js",
		"lint": "biome check --write",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@prisma/client": "^7.0.0",
		"@repo/db": "workspace:*",
		"@repo/schema": "workspace:*",
		"ai": "^6.0.141",
		"cors": "^2.8.5",
		"dotenv": "catalog:",
		"express": "^5.1.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@repo/biome-config": "workspace:^",
		"@repo/typescript-config": "workspace:*",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.3",
		"@types/node": "catalog:",
		"tsup": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
