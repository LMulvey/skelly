{
	"name": "@repo/ui",
	"version": "0.0.0",
	"private": true,
	"imports": {
		"#utils": "./src/utils.ts",
		"#components/*": "./src/components/*",
		"#styles/*": "./src/styles/*"
	},
	"exports": {
		"./styles.css": "./src/styles/globals.css",
		"./*": "./src/components/ui/*.tsx"
	},
	"scripts": {
		"build:styles": "tailwindcss -i ./src/styles/globals.css -o ./dist/index.css",
		"build:components": "tsup src/**/*.ts src/**/*.tsx --format esm --target es2022 --out-dir dist --dts --clean",
		"dev:styles": "tailwindcss -i ./src/styles/globals.css -o ./dist/index.css --watch",
		"dev:components": "tsup src/**/*.ts src/**/*.tsx --format esm --target es2022 --out-dir dist --dts --watch",
		"lint": "biome check --write",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@repo/biome-config": "workspace:^",
		"@repo/tailwind-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/cli": "^4.1.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.7.0",
		"radix-ui": "^1.4.3",
		"react": "catalog:",
		"react-dom": "catalog:",
		"shadcn": "^4.1.1",
		"tailwind-merge": "^3.3.1",
		"tailwindcss": "catalog:",
		"tw-animate-css": "^1.4.0"
	}
}
