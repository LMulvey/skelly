{
	"name": "@repo/schema",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"exports": {
		"./item": {
			"types": "./dist/item.d.ts",
			"default": "./dist/item.js"
		},
		"./error": {
			"types": "./dist/error.d.ts",
			"default": "./dist/error.js"
		}
	},
	"scripts": {
		"dev": "tsup src/index.ts src/item.ts src/error.ts --format esm --target es2022 --out-dir dist --dts --watch",
		"build": "tsup src/index.ts src/item.ts src/error.ts --format esm --target es2022 --out-dir dist --dts --clean",
		"start": "node dist/index.js",
		"lint": "biome check --write",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@repo/biome-config": "workspace:^",
		"@repo/typescript-config": "workspace:*",
		"@types/node": "catalog:",
		"tsup": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
