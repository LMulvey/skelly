{
	"name": "@repo/db",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "docker compose up -d --remove-orphans && docker compose logs -f postgres",
		"start": "docker compose up -d --remove-orphans",
		"stop": "docker compose down --remove-orphans",
		"reset": "docker compose down -v --remove-orphans",
		"logs": "docker compose logs -f postgres",
		"build": "prisma generate",
		"generate": "prisma generate",
		"migrate:dev": "prisma migrate dev",
		"migrate:deploy": "prisma migrate deploy",
		"seed": "tsx src/seed.ts",
		"studio": "prisma studio",
		"lint": "biome check --write",
		"check-types": "tsc --noEmit",
		"prebuild": "pnpm run generate",
		"predev": "pnpm run generate"
	},
	"exports": {
		".": "./src/client.ts"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"@prisma/client-runtime-utils": "^7.6.0",
		"dotenv": "catalog:",
		"pg": "^8.16.3"
	},
	"devDependencies": {
		"@repo/biome-config": "workspace:^",
		"@repo/typescript-config": "workspace:*",
		"@types/node": "catalog:",
		"@types/pg": "^8.16.0",
		"dotenv": "catalog:",
		"prisma": "^7.6.0",
		"typescript": "catalog:"
	}
}
